---
layout: layout.njk
---
<div class="content markdown-body">
  {{ content | safe }}
</div>

{% if collections.posts | length %}
<section class="content post-index" aria-labelledby="posts-heading">
  <h2 id="posts-heading">記事</h2>
  <ul class="post-index__list">
    {% for post in collections.posts %}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      {% if post.date %}
      <span class="post-index__date">{{ post.date | isoDate }}</span>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}
